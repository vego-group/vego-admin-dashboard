# ──────────────────────────────────────────────────────────────────────────────
# MyVego Fleet Dashboard — environment variables
#
# Copy this file to .env.local and fill in the real values.
# Variables starting with NEXT_PUBLIC_ are exposed to the browser.
# ──────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash).
# All fleet-admin requests are prefixed automatically:
#   e.g. https://api.myvego.com/api  →  https://api.myvego.com/api/fleet-admin/dashboard
NEXT_PUBLIC_API_URL=https://api.myvego.com/api

# Map tiles API key (used by Leaflet / Mapbox layers)
NEXT_PUBLIC_MAP_TILES_KEY=your-map-tiles-key
